{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mbs/blob-container-block",
	"version": "1.0.0",
	"title": "Blob Container Block",
	"category": "media",
	"icon": "email",
	"keywords": ["blob", "container", "cover"],
	"description": "A blob container block for clipping content.",
	"attributes": {
		"blobType": {
			"type": "number",
			"enum": [1, 2, 3, 4, 5],
			"default": 1
		},
		"fillColor": {
			"type": "string",
			"default": "primary"
		}
	},
	"supports": {
		"html": false,
		"color": {
			"background": true,
			"text": true
		},
		"dimensions": {
			"aspectRatio": false,
			"minHeight": true
		},
		"spacing": {
			"margin": true,
			"padding": false,
			"blockGap": false
		}
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
