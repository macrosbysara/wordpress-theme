{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "47rem",
			"wideSize": "82.5rem"
		},
		"spacing": {
			"blockGap": true,
			"margin": true,
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Extra Small",
					"size": ".25rem",
					"slug": "xs"
				},
				{
					"name": "Small",
					"size": ".5rem",
					"slug": "sm"
				},
				{
					"name": "Base",
					"size": "1rem",
					"slug": "base"
				},
				{
					"name": "Large",
					"size": "1.5rem",
					"slug": "lg"
				},
				{
					"name": "Extra Large",
					"size": "3rem",
					"slug": "xl"
				}
			]
		},
		"color": {
			"defaultPalette": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"palette": [
				{
					"name": "Primary",
					"slug": "primary",
					"color": "rgb(60, 28, 18)"
				},
				{
					"name": "Gray",
					"slug": "gray",
					"color": "rgb(90, 88, 92)"
				},
				{
					"name": "Primary Light",
					"slug": "primary-light",
					"color": "rgb(116, 60, 24)"
				},
				{
					"name": "Secondary",
					"slug": "secondary",
					"color": "rgb(135, 82, 66)"
				},
				{
					"name": "Secondary Light",
					"slug": "secondary-light",
					"color": "rgb(209, 188, 181)"
				},
				{
					"name": "White",
					"slug": "white",
					"color": "rgb(255, 255, 255)"
				},
				{
					"name": "Black",
					"slug": "black",
					"color": "rgb(0, 0, 0)"
				},
				{
					"name": "Sage",
					"slug": "sage",
					"color": "rgb(33, 79, 76)"
				},
				{
					"name": "Muted Orange",
					"slug": "muted-orange",
					"color": "rgb(193, 128, 98)"
				},

				{
					"name": "Drop Shadow",
					"slug": "drop-shadow",
					"color": "rgba(0, 0, 0, 0.35)"
				}
			]
		},
		"typography": {
			"fluid": true,
			"fontWeight": true,
			"customFontSize": false,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"name": "Mulish (Sans)",
					"slug": "body",
					"fontFamily": "Mulish, Helvetica, sans-serif",
					"fontFace": [
						{
							"fontStyle": "normal",
							"fontWeight": "400 700",
							"fontFamily": "Mulish, Helvetica, sans-serif",
							"src": "[file:./assets/fonts/Mulish/Mulish-VariableFont_wght.ttf]"
						}
					]
				},
				{
					"name": "Cormorant (Serif)",
					"slug": "headings",
					"fontFamily": "'Cormorant', Garamond, serif",
					"fontFace": [
						{
							"fontStyle": "normal",
							"fontWeight": "400 700",
							"fontFamily": "'Cormorant', Garamond, serif",
							"src": "[file:./assets/fonts/Cormorant/Cormorant-VariableFont_wght.ttf]"
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": ".875rem",
					"name": "Extra Small",
					"fluid": false
				},
				{
					"slug": "root",
					"size": "1rem",
					"name": "Root",
					"fluid": {
						"min": "1rem",
						"max": "1.25rem"
					}
				},
				{
					"slug": "sm",
					"size": "1.2rem",
					"name": "Small (H6)",
					"fluid": {
						"min": "1.2rem",
						"max": "1.5rem"
					}
				},
				{
					"slug": "md",
					"size": "1.44rem",
					"name": "Medium (H5)",
					"fluid": {
						"min": "1.44rem",
						"max": "1.88rem"
					}
				},
				{
					"slug": "lg",
					"size": "1.728rem",
					"name": "Large (H4)",
					"fluid": {
						"min": "1.728rem",
						"max": "2.16rem"
					}
				},
				{
					"slug": "xl",
					"size": "2.074rem",
					"name": "XL (H3)",
					"fluid": {
						"min": "2.074rem",
						"max": "2.592rem"
					}
				},
				{
					"slug": "xxl",
					"size": "2.488rem",
					"name": "2XL (H2)",
					"fluid": {
						"min": "2.488rem",
						"max": "3.11rem"
					}
				},
				{
					"slug": "xxxl",
					"size": "2.986rem",
					"name": "3XL (H1)",
					"fluid": {
						"min": "2.986rem",
						"max": "3.73rem"
					}
				}
			]
		},
		"useRootPaddingAwareAlignments": true,
		"lightbox": {
			"enabled": true
		},
		"dimensions": {
			"aspectRatio": true,
			"minHeight": true
		},
		"position": {
			"sticky": true
		},
		"custom": {
			"transition": {
				"timing": "ease-in-out",
				"duration": ".15s",
				"standard": "var(--wp--custom--transition--duration) var(--wp--custom--transition--timing)"
			},
			"border": {
				"radius": {
					"rounded-sm": "10px",
					"rounded": "20px",
					"pill": "50rem"
				},
				"width": {
					"buttons": "2px",
					"forms": "1px"
				}
			},
			"colors": {
				"success": "#3F6F5E",
				"error": "#a63c3c",
				"warning": "#C18A3A",
				"info": "#297681"
			}
		}
	},
	"styles": {
		"spacing": {
			"margin": {
				"bottom": "0",
				"left": "0",
				"right": "0",
				"top": "0"
			},
			"padding": {
				"bottom": "0",
				"left": "calc(var(--wp--preset--spacing--lg) * .5)",
				"right": "calc(var(--wp--preset--spacing--lg) * .5)",
				"top": "0"
			},
			"blockGap": "var:preset|spacing|sm"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|body",
			"fontSize": "var:preset|font-size|root",
			"fontWeight": "400",
			"fontStyle": "normal",
			"lineHeight": "1.5"
		},
		"color": {
			"text": "var:preset|color|primary"
		},
		"css": "text-wrap:pretty",
		"blocks": {
			"core/cover": {
				"spacing": {
					"padding": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					},
					"blockGap": "var:preset|spacing|base"
				}
			},
			"core/group": {
				"spacing": {
					"blockGap": "var:preset|spacing|base"
				}
			},
			"core/button": {
				"variations": {
					"outline": {
						"border": {
							"radius": "var:custom|border|radius|pill",
							"width": "var:custom|border|width|buttons",
							"color": "var:preset|color|primary"
						},
						"spacing": {
							"padding": {
								"top": "var:preset|spacing|base",
								"right": "var:preset|spacing|lg",
								"bottom": "var:preset|spacing|base",
								"left": "var:preset|spacing|lg"
							},
							"blockGap": "var:preset|spacing|base"
						},
						"typography": {
							"fontFamily": "var:preset|font-family|body",
							"fontSize": "var:preset|font-size|root"
						},
						"color": {
							"text": "var:preset|color|primary"
						}
					}
				}
			},
			"core/buttons": {
				"spacing": { "blockGap": "var:preset|spacing|base" }
			},
			"core/columns": {
				"spacing": { "blockGap": "var:preset|spacing|base" }
			},
			"core/image": {
				"variations": {
					"rounded": {
						"border": {
							"radius": "var:custom|border|radius|rounded"
						}
					},
					"rounded-shadow": {
						"border": {
							"radius": "var:custom|border|radius|rounded"
						},
						"shadow": "20px 16px 0px var(--wp--preset--color--secondary-light)"
					}
				}
			},
			"core/details": {
				"color": {
					"background": "var:preset|color|secondary-light",
					"text": "var:preset|color|white"
				},
				"border": {
					"radius": "var:custom|border|radius|rounded",
					"width": "var:custom|border|width|forms",
					"color": "var:preset|color|primary-light"
				},
				"elements": {
					"link": {
						"color": { "text": "var:preset|color|white" }
					}
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|sm",
						"bottom": "var:preset|spacing|sm",
						"left": "var:preset|spacing|sm",
						"right": "var:preset|spacing|sm"
					},
					"blockGap": "var:preset|spacing|sm"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|headings",
					"fontSize": "var:preset|font-size|md"
				}
			}
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xxxl"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|xxl"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|xl"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|lg"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|sm"
				}
			},
			"heading": {
				"color": {
					"text": "var:preset|color|primary"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|headings",
					"fontWeight": "700",
					"lineHeight": "calc(3ex + 4px)"
				},
				"css": "text-wrap:pretty"
			},
			"link": {
				"color": { "text": "var:preset|color|primary-light" },

				":link": {
					"color": { "text": "var:preset|color|primary-light" }
				},
				":visited": {
					"color": { "text": "var:preset|color|primary-light" }
				},
				":hover": {
					"color": { "text": "var:preset|color|primary" }
				}
			},
			"button": {
				"border": {
					"radius": "var:custom|border|radius|pill",
					"width": "var:custom|border|width|buttons",
					"color": "var:preset|color|primary"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|sm",
						"right": "var:preset|spacing|lg",
						"bottom": "var:preset|spacing|sm",
						"left": "var:preset|spacing|lg"
					},
					"margin": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					},
					"blockGap": "var:preset|spacing|base"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontSize": "var:preset|font-size|root"
				},
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|white"
				}
			},
			"select": {
				"typography": {
					"fontFamily": "inherit",
					"fontSize": "inherit",
					"lineHeight": "inherit",
					"textTransform": "none"
				},
				"color": {
					"background": "transparent",
					"text": "var:preset|color|primary"
				},
				"spacing": {
					"padding": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					},
					"margin": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					}
				},
				"border": {
					"color": "var:preset|color|primary",
					"width": "var:custom|border|width|forms",
					"radius": "var:custom|border|radius|rounded-sm"
				},
				"css": "box-sizing:border-box;outline:none;cursor:inherit;overflow-wrap:normal;appearance:none;display:block;width:100%;&:disabled {background-color:var(--wp--preset--color--gray);border-color:var(--wp--preset--color--gray);color:black;cursor:not-allowed;opacity:.5;}"
			},
			"textInput": {
				"border": {
					"radius": "var:custom|border|radius|rounded-sm",
					"width": "var:custom|border|width|forms",
					"color": "var:preset|color|primary"
				},
				"typography": {
					"fontFamily": "inherit",
					"fontSize": "inherit",
					"lineHeight": "inherit"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					},
					"padding": {
						"top": ".375rem",
						"right": ".75rem",
						"bottom": ".375rem",
						"left": ".75rem"
					}
				},
				"css": "background-clip:padding-box;appearance:none;display:block;width:100%;max-width:100%;box-sizing:border-box;&:disabled{opacity: 1;background-color: #e0e0e0;}accent-color:var(--wp--preset--color--primary);"
			}
		}
	}
}
